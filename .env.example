HOST=0.0.0.0
PORT=7055
DEBUG=false

# Required: one or more cookies.
# For multiple cookies, prefer newline or "||" as separator. Avoid commas, because a single cookie string may contain commas.
# You can use either full cookie entries with session_id=... or only session id values.
GS_COOKIE=session_id=replace_me

# Optional: API keys for Authorization: Bearer <key>, split by comma
API_SECRET=123456

# Optional proxy for upstream requests
PROXY_URL=

# Optional recaptcha token provider, must expose GET /genspark
# returning: {"code":200,"token":"..."}
RECAPTCHA_PROXY_URL=

# Optional route prefix, e.g. hf => /hf/v1/chat/completions
ROUTE_PREFIX=

# Timezone in Docker (optional)
TZ=Asia/Shanghai

AUTO_DEL_CHAT=0
REQUEST_RATE_LIMIT=60
AUTO_MODEL_CHAT_MAP_TYPE=1
MODEL_CHAT_MAP=
SESSION_IMAGE_CHAT_MAP=
RATE_LIMIT_COOKIE_LOCK_DURATION=600
REASONING_HIDE=0
PRE_MESSAGES_JSON=

UPSTREAM_BASE_URL=https://www.genspark.ai
REQUEST_TIMEOUT_SECONDS=120
ADMIN_STATE_FILE=./data/runtime-state.json
